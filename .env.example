# Copy these keys into Vercel → Project → Settings → Environment Variables.
# Values below are placeholders — use your real insight-meta credentials.

# --- Firebase Admin (server-side) ---
# Full service-account JSON on ONE line (from Firebase Console → Service Accounts).
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"insight-meta","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@insight-meta.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

# --- Firebase client (public, browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBq5kOKn1UfmgQNbFEn_q7gkzfR0GzCA80
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=insight-meta.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=insight-meta
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=insight-meta.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=98791505594
NEXT_PUBLIC_FIREBASE_APP_ID=1:98791505594:web:be2a7d4806af893794cc83

# --- Restrict Google sign-in to your company domain ---
NEXT_PUBLIC_ALLOWED_AUTH_DOMAIN=digitalmojo.in

# --- Token encryption (32+ char random string) ---
ENCRYPTION_KEY=change_me_to_a_random_32char_secret

# --- Google Ads (optional; only if you connect Google Ads later) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# In production, point this at your deployed domain, per workspace slug:
# GOOGLE_REDIRECT_URI=https://<your-domain>/api/workspaces/<slug>/google/callback
